{
    "name": "@core-ai/repo",
    "private": true,
    "license": "MIT",
    "scripts": {
        "build": "turbo build",
        "test": "turbo test",
        "package": "changeset version",
        "publish": "changeset publish",
        "deploy": "turbo deploy",
        "dev": "turbo dev --continue=always",
        "lint": "turbo lint",
        "check-types": "turbo check-types",
        "format": "prettier --write \"**/*.{ts,tsx,md,json,js,mjs}\"",
        "changeset": "changeset",
        "release:check": "npm run build && turbo lint check-types",
        "release:version": "changeset version",
        "release:publish": "changeset publish"
    },
    "devDependencies": {
        "@changesets/cli": "^2.29.8",
        "prettier": "^3.4.2",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "turbo": "^2.4.0",
        "typescript": "5.7.3",
        "vitest": "^3.2.3"
    },
    "engines": {
        "node": ">=22"
    },
    "packageManager": "npm@10.8.2",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "dependencies": {
        "dotenv": "^17.2.2"
    }
}
