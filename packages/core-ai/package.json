{
    "name": "@core-ai/core-ai",
    "version": "0.5.0",
    "description": "Type-safe LLM abstraction layer over native provider SDKs",
    "license": "MIT",
    "author": "Omnifact (https://omnifact.ai)",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/agdevhq/core-ai.git",
        "directory": "packages/core-ai"
    },
    "keywords": [
        "llm",
        "ai",
        "sdk",
        "openai",
        "anthropic",
        "google-genai"
    ],
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "build": "tsup",
        "lint": "eslint src/ --max-warnings 0",
        "check-types": "tsc --noEmit",
        "prepublishOnly": "npm run build",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "zod": "^3.25.0 || ^4.0.0",
        "zod-to-json-schema": "^3.25.1"
    },
    "devDependencies": {
        "@core-ai/eslint-config": "^0.0.0",
        "@core-ai/typescript-config": "^0.0.0",
        "typescript": "^5.7.3",
        "vitest": "^3.2.4"
    }
}
