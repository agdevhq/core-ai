{
    "name": "@core-ai/core-ai",
    "version": "0.0.1",
    "description": "Type-safe LLM abstraction layer over native provider SDKs",
    "private": true,
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./openai": "./src/providers/openai.ts",
        "./anthropic": "./src/providers/anthropic.ts",
        "./google-genai": "./src/providers/google-genai.ts"
    },
    "scripts": {
        "lint": "eslint src/ --max-warnings 0",
        "check-types": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@core-ai/anthropic": "*",
        "@core-ai/google-genai": "*",
        "@core-ai/openai": "*",
        "zod": "^3.25.76",
        "zod-to-json-schema": "^3.24.5"
    },
    "devDependencies": {
        "@core-ai/eslint-config": "^0.0.0",
        "@core-ai/typescript-config": "^0.0.0",
        "typescript": "^5.7.3",
        "vitest": "^3.2.4"
    }
}
